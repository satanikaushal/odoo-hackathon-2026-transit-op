PORT=3000
NODE_ENV=development

# Local dev DB: run `bunx prisma dev` (spins up Postgres with no Docker needed),
# then use the raw TCP URLs it prints (see README for why we don't use the
# prisma+postgres:// proxy URL).
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:51215/template1?sslmode=disable"

JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
