PORT=3000
NODE_ENV=development

# Local dev DB: `docker compose up -d` (see README) starts Postgres with these
# exact databases already created, so these values work as-is.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/transitops?sslmode=disable"
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:5432/transitops_shadow?sslmode=disable"

JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
