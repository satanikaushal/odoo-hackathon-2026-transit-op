PORT=3000
NODE_ENV=development

# Local dev DB: `docker compose up -d` (see README) starts Postgres with these
# exact databases already created, so these values work as-is.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/transitops?sslmode=disable"
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:5432/transitops_shadow?sslmode=disable"

JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# Background jobs (BullMQ). Requires Redis. Set ENABLE_JOBS=false to disable.
ENABLE_JOBS=true
REDIS_URL="redis://localhost:6379"

# License-expiry reminder job.
LICENSE_REMINDER_DAYS=30
LICENSE_REMINDER_CRON="0 8 * * *"

# SMTP mail transport. Leave SMTP_HOST unset to run the mailer in log-only mode
# (no emails sent — useful for local dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="TransitOps <no-reply@transitops.local>"
